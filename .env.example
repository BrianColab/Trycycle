# ─────────────────────────────────────────────────────────────────────────────
# TryCycle — Environment Variables
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real credentials.
# ─────────────────────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string used by Prisma.
#
# Local development:
#   DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/trycycle"
#
# Railway:
#   Add a PostgreSQL service to your Railway project, then set:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   Railway will substitute the real connection string at runtime.
DATABASE_URL=


# ── Site URL ──────────────────────────────────────────────────────────────────
# Required. The public base URL of the app. Used for links in emails and
# any server-side URL construction.
#
# Local:       http://localhost:3000
# Railway:     https://your-project.up.railway.app  (or your custom domain)
NEXT_PUBLIC_SITE_URL=


# ── Email — Resend (optional) ─────────────────────────────────────────────────
# Optional. If these variables are missing or empty, bookings still save
# to the database and the API returns success with emailSkipped: true.
# A warning is logged server-side. No booking is lost.
#
# To enable emails:
#   1. Create a Resend account and verify your sending domain.
#   2. Create an API key in the Resend dashboard.
#   3. Set APPOINTMENT_FROM_EMAIL to an address on your verified domain.
#
# APPOINTMENT_ADMIN_FALLBACK_EMAIL is optional. If set, every new booking
# also sends a copy to this address.
RESEND_API_KEY=
APPOINTMENT_FROM_EMAIL=
APPOINTMENT_ADMIN_FALLBACK_EMAIL=
